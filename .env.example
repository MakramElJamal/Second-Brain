# Copy this to .env (gitignored) and fill it in. NEVER commit real secrets.
# Easiest path: run  .\scripts\setup.ps1  which generates this file for you with
# fresh secrets — you only supply your vault path.

# --- Vault ---------------------------------------------------------------
# Absolute path to your vault (the folder of .md files).
VAULT_PATH=C:\Users\you\Documents\My Vault

# --- Secrets (fail closed if unset) --------------------------------------
# Per-request bearer secret. Generate:
#   python -c "import secrets;print(secrets.token_hex(32))"
VAULT_MCP_TOKEN=

# Interactive OAuth login gate: the human login required before ANY client is
# authorized. Generate the password:
#   python -c "import secrets;print(secrets.token_urlsafe(24))"
VAULT_OAUTH_USERNAME=obsidian
VAULT_OAUTH_PASSWORD=

# --- Network (bind loopback; the tunnel reaches it over localhost) -------
VAULT_MCP_HOST=127.0.0.1
VAULT_MCP_PORT=8531

# --- Anti-spoofing (set AFTER you learn your tunnel URL, then restart) ---
# Set BOTH to your public tunnel origin, e.g. https://something.trycloudflare.com
# Pinning these stops a spoofed Host/X-Forwarded-Host from redirecting OAuth.
# Leave blank for local-only (loopback) use.
VAULT_MCP_PUBLIC_URL=
VAULT_MCP_ALLOWED_HOSTS=

# --- Secret/audit storage (keep OUT of the vault and the repo) -----------
# Relative paths resolve against this project directory.
OAUTH_CLIENTS_PATH=.secrets\oauth_clients.json
VAULT_AUDIT_LOG_PATH=.secrets\audit.jsonl
